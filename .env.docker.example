# ============================================================
#  R-BOT — configuration d'une instance client
#  Rempli par l'éditeur (toi) avant livraison. Une valeur par client.
# ============================================================

# --- Domaines du client (derrière un reverse proxy HTTPS) ---
NEXTAUTH_URL=https://bot.client.com
NEXT_PUBLIC_VIEWER_URL=https://botview.client.com

# --- Base de données (interne au compose, ne pas changer l'hôte) ---
DATABASE_URL=postgresql://postgres:typebot@typebot-db-docker:5432/typebot?schema=public

# --- Secret de chiffrement : UNIQUE et 32 caractères, différent par client ---
ENCRYPTION_SECRET=change-me-32-caracteres-uniques-

# --- Stockage MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
S3_ENDPOINT=typebot-minio
S3_PORT=9000
S3_SSL=false
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-me-minio-password
S3_BUCKET=bot
S3_REGION=us-east-1

# --- LICENCE (générée par TOI avec ta clé privée, durée au choix) ---
# Sur ton Mac : LICENSE_PRIVATE_KEY=... node scripts/license-generate.mjs <années> <client>
LICENSE_KEY=colle-ici-le-LICENSE_KEY-genere-pour-ce-client

# --- Admin (email autorisé en plus du rôle ADMIN en base) ---
# ADMIN_EMAIL=admin@client.com

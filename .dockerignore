# Logs
############################################
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*

############################################
# Tests
############################################
**/__tests__
**/*.test.*
**/coverage

############################################
# IDE
############################################
.vscode
.idea
*.iml

############################################
